// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Site {
  id            String  @id @default(uuid())
  name          String
  domain        String?
  defaultLocale String  @default("es")
  apiKey        String  @unique @default(uuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  pages          Page[]
  users          User[]
  components     Component[]
  variables      Variable[]
  assets         Asset[]
  contentModels  ContentModel[]
  events         Event[]
  gitConnection  GitConnection?
  gitActivities  GitActivity[]
  deployments    DeploymentRecord[]
  userId         String?   // Added userId to Site
  owner          User?     @relation("SiteOwner", fields: [userId], references: [id])
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  /// Null si el usuario solo usa OAuth (Google/GitHub login).
  passwordHash String?
  role         String   @default("editor") // admin | editor | viewer
  siteId       String?
  site         Site?     @relation(fields: [siteId], references: [id])
  createdAt    DateTime  @default(now())
  ownedSites   Site[]    @relation("SiteOwner")

  /// Token OAuth de GitHub API (scope repo).
  githubAccessToken String?
  githubUsername    String?

  publications Publication[]
}

model Page {
  id          String   @id @default(uuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])
  name        String
  urlPath     String
  title       String?
  description String?
  status      String   @default("draft") // draft | published | archived
  blocksJson  String   @default("[]") // JSON serialized BSBlock[]
  script      String?  // JavaScript block for page-level logic
  variantsJson String  @default("[]") // JSON serialized BSVariant[]
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publications Publication[]

  @@unique([siteId, urlPath])
  @@index([siteId, status])
}

model Component {
  id              String   @id @default(uuid())
  siteId          String
  site            Site     @relation(fields: [siteId], references: [id])
  name            String
  description     String?
  rootBlockJson   String   // JSON serialized BSBlock
  /// Design system del workspace (`DesignSystemLibrary.id`) o null = sin etiqueta / todos.
  designSystemId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([siteId, designSystemId])
}

model Variable {
  id          String   @id @default(uuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])
  key         String
  type        String   // ScalarFieldType
  valueJson   String   // JSON serialized value
  description String?

  @@unique([siteId, key])
}

model Asset {
  id        String   @id @default(uuid())
  siteId    String
  site      Site     @relation(fields: [siteId], references: [id])
  name      String
  url       String
  mimeType  String
  sizeBytes Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

model ContentModel {
  id          String   @id @default(uuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])
  name        String
  displayName String
  fieldsJson  String   @default("[]") // JSON serialized BSFieldDefinition[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([siteId, name])
}

model Publication {
  id          String   @id @default(uuid())
  pageId      String
  page        Page     @relation(fields: [pageId], references: [id])
  siteId      String
  publishedBy String
  user        User     @relation(fields: [publishedBy], references: [id])
  snapshotJson String  // JSON serialized BSPage at publish time
  publishedAt  DateTime @default(now())

  @@index([pageId])
}

model Event {
  id          String   @id @default(uuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])
  pageId      String
  type        String   // view | click | conversion | custom
  target      String?
  metadataJson String  @default("{}")
  sessionId   String
  createdAt   DateTime @default(now())

  @@index([siteId, pageId, type])
}

model GitConnection {
  id               String   @id @default(uuid())
  siteId           String   @unique
  site             Site     @relation(fields: [siteId], references: [id])

  provider         String   @default("github") // github
  repoFullName     String
  defaultBranch    String   @default("main")
  exportPath       String   @default(".buildev/buildev-site.json")

  activeBranch     String?  // branch currently used by app

  vercelProjectId  String?
  vercelTeamId     String?
  productionDomain String?

  autoPreviewOnPush Boolean @default(true)
  autoDeployOnPr    Boolean @default(true)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model GitActivity {
  id            String   @id @default(uuid())
  siteId        String
  site          Site     @relation(fields: [siteId], references: [id])

  type          String   // import | pull | push | pr_opened | branch_created | restore | deploy
  status        String   @default("success") // success | failed | pending
  actor         String?

  branch        String?
  baseBranch    String?
  commitSha     String?
  prNumber      Int?

  diffSummaryJson String? // JSON summary or diff metadata
  snapshotJson    String? // JSON export snapshot for rollback/diff

  createdAt     DateTime @default(now())

  @@index([siteId, createdAt])
}

model DeploymentRecord {
  id          String   @id @default(uuid())
  siteId      String
  site        Site     @relation(fields: [siteId], references: [id])

  provider    String   @default("vercel") // vercel
  environment String   // preview | production
  url         String
  status      String   @default("queued") // queued | building | ready | error

  branch      String?
  commitSha   String?

  createdAt   DateTime @default(now())

  @@index([siteId, createdAt])
}
