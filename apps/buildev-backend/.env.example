# Copia este archivo a `.env` en la misma carpeta y rellena los valores.
# PORT por defecto 4000 (debe coincidir con VITE_DEV_API_PROXY / proxy de Vite en el front).
# PORT=4000
#
# Solo local: si es true, el API ignora JWT y usa el primer usuario/sitio de la BD (NO usar en producción).
# AUTH_DEV_BYPASS=true
#
# --- Producción (Vercel, Railway, Render, etc.) ---
#
# Vercel (proyecto separado del front):
#   · Root Directory del proyecto: apps/buildev-backend
#   · Tras el deploy, la URL del API será p. ej. https://xxx.vercel.app
#   · En el proyecto del FRONT (Vercel): VITE_API_URL=https://xxx.vercel.app (sin / al final)
#   · VERCEL=1 en runtime: no hace falta cambiar PORT; el código ya no usa app.listen en Vercel.
#
# DATABASE_URL debe existir en el build del API para que `yarn vercel-build` ejecute `prisma migrate deploy`.
# En Vercel: proyecto del backend → Settings → Environment Variables → DATABASE_URL (Production + Preview).
# Si el build no puede migrar, ejecuta una vez en tu Postgres (Neon/Supabase):
#   ALTER TABLE "User" ALTER COLUMN "passwordHash" DROP NOT NULL;
#   ALTER TABLE "User" ADD COLUMN "githubAccessToken" TEXT;
#   ALTER TABLE "User" ADD COLUMN "githubUsername" TEXT;
#
# Supabase recomendado con Prisma:
# - DATABASE_URL: Transaction Pooler (puerto 6543) + pgbouncer
# - DIRECT_URL: conexión directa (puerto 5432) para migraciones/DDL
# DATABASE_URL=postgresql://USER:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://USER:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres

# URL pública del front (Vercel), SIN barra final. Si está definida, el login OAuth usa
# PUBLIC_APP_URL + /auth/github y + /auth/google salvo que sobrescribas con *_LOGIN_REDIRECT_URI.
# PUBLIC_APP_URL=https://tu-proyecto.vercel.app
#
# Previews de Vercel (URL tipo https://buildev-xxx.vercel.app): GitHub y Google exigen registrar
# cada redirect URI explícitamente. Opciones: (1) añadir en la consola de cada proveedor las URIs
# de preview, o (2) probar OAuth solo contra el despliegue de Production del front, o (3) definir
# GITHUB_LOGIN_REDIRECT_URI / GOOGLE_LOGIN_REDIRECT_URI por entorno (Preview vs Production) en Vercel.

# ═══════════════════════════════════════════════════════════════════════════════
# GitHub — Client ID y Client Secret (OAuth App)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Cómo conseguirlos (resumen):
#
#  1. Inicia sesión en https://github.com
#  2. Avatar (arriba derecha) → Settings
#  3. Menú izquierdo, abajo del todo → Developer settings
#  4. OAuth Apps → New OAuth App (o elige una app ya creada)
#  5. Rellena:
#       Application name     → ej. Buildev
#       Homepage URL         → ej. http://localhost:5173  o  tu PUBLIC_APP_URL
#       Authorization callback URL → GitHub exige la URL exacta; añade TODAS las que uses:
#         · Vincular repositorio (usuario logueado): …/github/callback
#         · Inicio de sesión con GitHub: …/auth/github
#       En la misma pantalla suele haber «Add» / otra línea para más URLs de callback.
#  6. Register application → copia el «Client ID» (visible siempre).
#  7. «Generate a new client secret» → copia el secret EN ESE MOMENTO (GitHub no lo muestra entero después).
#  8. Pega los valores abajo (sin comillas salvo que tu host las requiera). Reinicia el API.
#
# Guía oficial: https://docs.github.com/es/apps/oauth-apps/building-oauth-apps/creating-an-oauth-app
# Referencia API: https://docs.github.com/en/apps/oauth-apps/building-oauth-apps/authorizing-oauth-apps
#
# Plantilla (reemplaza los valores de ejemplo por los tuyos):
#
# GITHUB_CLIENT_ID=Ov23liEjemploClientIdDeGitHub
# GITHUB_CLIENT_SECRET=el_secret_largo_que_muestra_github_al_pulsar_Generate_new_client_secret
#
# Si defines PUBLIC_APP_URL, normalmente NO hace falta repetir las URLs de callback aquí
# (el backend arma …/github/callback y …/auth/github solo). Si no usas PUBLIC_APP_URL, descomenta:
# GITHUB_OAUTH_CALLBACK_URL=http://localhost:5173/github/callback
# GITHUB_LOGIN_REDIRECT_URI=http://localhost:5173/auth/github

# Descomenta y pega los valores reales (sin «REEMPLAZA» ni texto de ejemplo; si no, el API marcará OAuth como no listo).
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google — inicio de sesión / registro (OAuth 2.0). Redirect URI en Google Cloud Console.
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_LOGIN_REDIRECT_URI=http://localhost:5173/auth/google

# En Vercel (API): obligatorio un valor aleatorio largo (≥16 caracteres). Valores por defecto de ejemplo
# rechazan el arranque en runtime si VERCEL=1.
JWT_SECRET=change_me_in_production

# OpenAI (BYOK) — visión `/api/ai/vision` y chat `/api/ai/chat` vía `@buildev/ai-engine`.
# OPENAI_API_KEY=sk-...
# Opcional: modelo para el chat del editor (por defecto gpt-4o-mini).
# OPENAI_CHAT_MODEL=gpt-4o-mini
