# --- Desarrollo (Vite) ---
# GitHub OAuth (login / vincular): el Client ID y el Secret van en el BACKEND, no aquí.
# Plantilla y pasos: apps/buildev-backend/.env.example
#
# No pongas VITE_API_URL: el front llama a /api y Vite reenvía al backend (por defecto http://127.0.0.1:4000).
# Si el API escucha en otro host/puerto:
# VITE_DEV_API_PROXY=http://127.0.0.1:4000

# --- Producción (vite build) ---
# URL absoluta del API (sin barra final), p. ej. https://api.tudominio.com
# VITE_API_URL=
