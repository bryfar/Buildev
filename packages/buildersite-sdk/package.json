{
  "name": "@buildersite/sdk",
  "version": "0.2.0",
  "private": true,
  "description": "Buildersite SDK – headless content delivery for any JS/TS project",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue.d.ts",
      "default": "./dist/vue.js"
    }
  },
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "@buildersite/domain": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vue": "^3.5.15"
  },
  "peerDependencies": {
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  }
}
